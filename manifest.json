{
    "manifest_version": 3,
    "name": "YouTube Study Mode",
    "version": "1.0",
    "description": "Blocks distractions on YouTube.",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ]
}